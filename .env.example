# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@xxx.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@xxx.neon.tech/neondb?sslmode=require&pgbouncer=true"

# AWS SES (US East)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."

# Telegram Bot
TELEGRAM_BOT_TOKEN="123456:ABCdef"

# App
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_NAME="pingAurora"

# Google Maps Geocoding API (converts addresses to lat/lng coordinates)
# Get your key: https://console.cloud.google.com/apis/credentials
# Enable Geocoding API, create an API Key, and set HTTP referrer restrictions for security
GOOGLE_MAPS_API_KEY="AIzaSy..."

# Optional: Resend (alternative email)
RESEND_API_KEY="re_..."

